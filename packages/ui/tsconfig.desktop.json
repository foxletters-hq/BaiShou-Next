{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist/desktop",
    "rootDir": "src",
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strictNullChecks": false
  },
  "include": [
    "src/env.d.ts",
    "src/images.d.ts",
    "src/index.ts",
    "src/i18n.ts",
    "src/agent-gate/**/*",
    "src/desktop/**/*",
    "src/hooks/**/*",
    "src/theme/**/*",
    "src/utils/**/*",
    "src/assets/**/*",
    "src/shared/editor-menus/**/*",
    "src/shared/diary-codemirror/**/*"
  ],
  "exclude": ["src/native/**/*"]
}
