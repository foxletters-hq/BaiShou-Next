{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist/native",
    "rootDir": "src",
    "composite": true,
    "jsx": "react-native",
    "lib": ["ES2022"],
    "types": ["react-native"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strictNullChecks": false
  },
  "include": [
    "src/native/**/*",
    "src/theme/**/*"
  ],
  "exclude": ["src/web/**/*"]
}
