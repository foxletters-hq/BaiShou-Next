{
  "name": "@baishou/mobile",
  "main": "expo-router/entry",
  "version": "1.1.0",
  "scripts": {
    "commands": "node ../../scripts/commands-help.mjs mobile",
    "predev": "node ../../scripts/sync-app-icon.mjs && node ../../scripts/sync-app-version.mjs && pnpm run build:diary-editor",
    "dev": "node ./scripts/start-dev.mjs",
    "dev:clear": "node ./scripts/run-android.mjs",
    "install:apk": "node ./scripts/install-apk.mjs",
    "connect": "node ./scripts/connect-device.mjs",
    "fix": "node ../../scripts/run-with-hint.mjs \"对齐本目录 Expo SDK 55 依赖版本。\" npx expo install --fix",
    "export:android": "pnpm run build:diary-editor && expo export --platform android",
    "build:release": "node ./scripts/build-release-apk.mjs",
    "build:diary-editor": "vite build --config diary-editor-web/vite.config.ts && node diary-editor-web/scripts/generate-shell-html.mjs",
    "ios": "expo run:ios",
    "lint": "eslint . --cache",
    "typecheck": "tsc --noEmit",
    "test": "node ../../node_modules/vitest/vitest.mjs run --config vitest.config.mts"
  },
  "dependencies": {
    "@baishou/ai": "workspace:^",
    "@baishou/core-mobile": "workspace:^",
    "@baishou/database": "workspace:^",
    "@baishou/shared": "workspace:^",
    "@baishou/store": "workspace:*",
    "@baishou/ui": "workspace:*",
    "@expo/vector-icons": "^15.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.1.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.14",
    "@react-navigation/native": "^7.1.33",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "expo": "~55.0.26",
    "expo-application": "~55.0.15",
    "expo-audio": "~55.0.8",
    "expo-baishou-server": "link:modules/expo-baishou-server",
    "expo-clipboard": "^55.0.13",
    "expo-constants": "~55.0.16",
    "expo-crypto": "^55.0.15",
    "expo-dev-client": "~55.0.35",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-image-manipulator": "~55.0.17",
    "expo-image-picker": "^55.0.20",
    "expo-intent-launcher": "~55.0.12",
    "expo-linking": "~55.0.15",
    "expo-network": "~55.0.14",
    "expo-pdf-text-extract": "^1.1.0",
    "expo-router": "~55.0.16",
    "expo-sharing": "~55.0.20",
    "expo-splash-screen": "~55.0.21",
    "expo-sqlite": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-web-browser": "~55.0.14",
    "heroui-native": "^1.0.0-beta.10",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "react-native-zeroconf": "^0.14.0",
    "react-native-zip-archive": "^7.0.2",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.0",
    "tailwindcss": "^4.1.16",
    "uniwind": "^1.0.5",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.11.0",
    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@lezer/common": "^1.3.0",
    "@lezer/highlight": "^1.2.3",
    "@types/react": "~19.2.14",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "~5.9.2",
    "vite": "^7.1.10"
  },
  "private": true
}
