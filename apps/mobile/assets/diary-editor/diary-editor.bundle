rning_agent_db_read_partial:"部分旧版数据库未能读取，结果可能不完整",permission_required:"需要存储权限才能读取旧版数据，请授予「管理所有文件」后重试。",db_not_ready:"数据库尚未就绪，请稍候后重新扫描。",import_nothing_new:"没有新数据被导入（可能已全部存在）",reimport_confirm_title:"重复导入",reimport_confirm_message:"该板块已导入过，重复导入可能产生重复数据。是否继续？",warning_import_workspaces_first:"建议先导入「工作空间」，再导入日记与聊天记录，避免数据进错工作区",import_errors_detail:"{{detail}}",import_failures_detail:"失败示例：{{detail}}",persona_preview_line:"{{name}} · {{count}} 个属性",failure_samples_title:"部分条目导入失败：",failure_samples_more:"还有 {{count}} 条未显示",config_preview_providers:"AI 服务商与 API Key",config_preview_models:"全局对话 / 总结 / Embedding 模型",config_preview_theme:"主题色与明暗模式",config_preview_agent:"Agent 行为与人设指引",config_preview_rag:"RAG 检索与总结指令",config_preview_tools:"工具开关、联网搜索与 MCP",import_order_hint:"推荐顺序：全局（头像/身份卡/配置）→ 各工作空间（日记 + 伙伴与会话）",global_group_title:"全局数据",workspace_group_title:"工作空间",workspace_meta:"{{diaries}} 篇日记 · {{summaries}} 篇总结 · {{assistants}} 伙伴 · {{sessions}} 会话 · {{size}}",import_all_workspaces:"导入全部工作空间",import_all_workspaces_title:"导入全部工作空间",import_all_workspaces_confirm:"将依次导入每个工作空间的日记、伙伴与会话。是否继续？",choose_legacy_directory:"选择旧版目录",clear_custom_legacy_directory:"恢复自动检测",invalid_legacy_directory:"所选目录不是有效的旧版白守数据目录，请选择包含工作区的 BaiShou_Root 文件夹。",legacy_source_manual:"当前使用手动选择的旧版目录",legacy_source_flutter:"已自动定位到原版 Flutter 白守数据目录",legacy_source_migrated:"使用整包迁移记录的旧版目录",storage_entry_action:"按板块从旧版迁移数据",restart_title:"请重启应用",restart_message:"工作空间数据已导入完成。在重启之前，日记、总结与会话列表可能不会显示最新内容。为确保切换工作空间时数据正常刷新，请完全退出白守后重新打开应用，不要仅切到后台。"},emoji:{categories:"类别",no_native_support:"你的浏览器不支持彩色表情符号",favorites:"收藏",loading:"加载中…",error_load:"无法加载表情符号",picker_title:"表情符号选择器",keyboard_hint:"有搜索结果时，按键盘选择。",search:"搜索",search_results:"搜索结果",skin_tone_hint:"展开时选择肤色。",select_skin_tone:"选择肤色（当前肤色：{{skinTone}}）",skin_tone:"肤色",skin_default:"默认",skin_light:"浅色",skin_medium_light:"中浅色",skin_medium:"中等",skin_medium_dark:"中深色",skin_dark:"深色",category_custom:"自定义",category_smileys:"表情与情感",category_people:"人物与身体",category_animals:"动物与自然",category_food:"食物与饮料",category_travel:"旅行与地点",category_activities:"活动",category_objects:"物品",category_symbols:"符号",category_flags:"旗帜",personalize_avatar:"个性化图标",upload_avatar_hint:"从本地上传图片作为头像"},avatar:{zoom:"缩放",cancel:"取消",save_crop:"保存裁剪"},datetime:{year_suffix:"年",month_suffix:"月",day_suffix:"日"},provider:{siliconflow:"硅基流动 (SiliconFlow)",ali_bailian:"通义千问 (百炼)",volcengine:"豆包 (火山引擎)",select_test_model:"请选择测试模型"},app:{operation_error:"操作异常",unknown_error:"未知网络或系统错误",system_warning:"系统警告",unknown_program_error:"程序发生未知错误"},version_control:{title:"版本控制",git_status_tooltip:"Git 在存储根目录管理全部工作区（Vault）的版本：记录修改历史、推送到远程仓库（GitHub/Gitee 等）备份，并支持多设备协作。若在文件同步或全量恢复时误还原了错误版本，可通过版本控制回滚或撤销变更。本功能仅在桌面端提供。",git_settings:"Git 设置",version_control:"版本控制",git_status:"Git 仓库状态",init_git:"初始化 Git 仓库",git_scope_desc:"Git 仓库位于存储根目录，统一管理其下全部工作区（Vault）的文件变更（日记、会话、附件等）。各工作区内的 `.baishou/` 不入版本库，由「文件同步」单独管理。",git_scope_help_aria:"Git 版本控制作用范围说明",git_scope_help_title:"版本控制说明",git_enabled:"已启用",author_signature:"Git 提交签名",author_name:"用户名 (user.name)",author_name_hint:"例如: latte",author_email:"邮箱 (user.email)",author_email_hint:"例如: latte@example.com",remote_url:"远程仓库地址",remote_config:"远程仓库配置",remote_config_help_aria:"远程仓库配置说明",remote_config_help_title:"远程仓库配置说明",remote_config_help:`Git 远程仓库用于备份「存储根目录」下全部工作区的内容文件（日记、附件等），与各工作区内的 .baishou/ 增量同步无关。

在本页配置：
1. 在 GitHub / Gitee 创建空的私有仓库
2. 远程地址填 HTTPS 克隆地址，例如 https://github.com/用户名/仓库名.git
3. 远程分支与线上一致（多为 main 或 master）
4. HTTPS 需填写平台用户名 + Personal Access Token（不是登录密码）
5. 填写后点击本区块右上角「保存」，再点「测试连接」

也可在存储根目录打开终端自行配置远程：
git remote add origin <仓库地址>
git branch -M main
git push -u origin main
