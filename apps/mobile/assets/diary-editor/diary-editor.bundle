ading:"Loading…",error_load:"Unable to load emoji",picker_title:"Emoji Picker",keyboard_hint:"When there are search results, use keyboard to select.",search:"Search",search_results:"Search Results",skin_tone_hint:"Select skin tone when expanded.",select_skin_tone:"Select skin tone (current: {{skinTone}})",skin_tone:"Skin Tone",skin_default:"Default",skin_light:"Light",skin_medium_light:"Medium Light",skin_medium:"Medium",skin_medium_dark:"Medium Dark",skin_dark:"Dark",category_custom:"Custom",category_smileys:"Smileys & Emotion",category_people:"People & Body",category_animals:"Animals & Nature",category_food:"Food & Drink",category_travel:"Travel & Places",category_activities:"Activities",category_objects:"Objects",category_symbols:"Symbols",category_flags:"Flags",personalize_avatar:"Personalize Avatar",upload_avatar_hint:"Upload an image from your device as avatar"},avatar:{zoom:"Zoom",cancel:"Cancel",save_crop:"Save Crop"},datetime:{year_suffix:"",month_suffix:"",day_suffix:""},provider:{siliconflow:"SiliconFlow",ali_bailian:"Alibaba Bailian (Qwen)",volcengine:"Volcengine (Doubao)",select_test_model:"Please select a test model"},app:{operation_error:"Operation Error",unknown_error:"Unknown network or system error",system_warning:"System Warning",unknown_program_error:"An unknown program error occurred"},version_control:{title:"Version Control",git_status_tooltip:"Git manages version history for all vaults under the storage root: track changes, push to remote repositories (GitHub/Gitee), and collaborate across devices. Use it to rollback mistaken restores from file sync or full backup. Desktop only.",git_settings:"Git Settings",version_control:"Version Control",git_status:"Git Repository Status",init_git:"Initialize Git Repository",git_scope_desc:"The Git repository lives at the storage root and tracks changes across all vaults (journals, sessions, attachments, etc.). Each vault's `.baishou/` directory is excluded and managed by File Sync instead.",git_scope_help_aria:"Git version control scope",git_scope_help_title:"Version control",git_enabled:"Enabled",author_signature:"Git Commit Signature",author_name:"Username (user.name)",author_name_hint:"e.g. latte",author_email:"Email (user.email)",author_email_hint:"e.g. latte@example.com",remote_url:"Remote Repository URL",remote_config:"Remote repository",remote_config_help_aria:"Remote repository setup help",remote_config_help_title:"Remote repository setup",remote_config_help:`The Git remote backs up content files under your storage root across all vaults (journals, attachments, etc.). It is separate from per-vault .baishou/ incremental sync.

Configure in this page:
1. Create an empty private repo on GitHub / Gitee
2. Remote URL: HTTPS clone URL, e.g. https://github.com/user/repo.git
3. Branch: match the remote default (often main or master)
4. For HTTPS: platform username + Personal Access Token (not your login password)
5. Click Save in this section, then Test connection

Or configure in a terminal at the storage root:
git remote add origin <repo-url>
git branch -M main
git push -u origin main
After that, you can enter the same URL here to push/pull from the app.`,remote_branch:"Remote Branch",remote_branch_default:"Default: main",remote_username:"Remote Username",remote_token:"Password / Access Token",remote_token_hint:"Password or personal access token",test_connection:"Test Connection",push:"Push to Remote",pull:"Pull from Remote",connection_success:"Connection successful",connection_failed:"Connection failed",push_success:"Push successful",git_push_failed:"Push failed",pull_success:"Pull successful",git_pull_failed:"Pull failed",conflict_detected:"Conflicts detected",resolve_ours:"Keep Local",resolve_theirs:"Keep Remote",commit_local:"Commit",commit_push:"Commit & Push",staged_changes:"Staged Changes",unstage_all:"Unstage All",no_staged_changes:"No staged changes",unstage:"Unstage",changes:"Changes",stage_all:"Stage All",discard_all:"Discard All",no_changes:"No changes",stage:"Stage",discard:"Discard",discard_confirm_title:"Discard changes?",discard_confirm_message_file:'Unstaged changes to "{{path}}" will be permanently discarded.',discard_confirm_message_untracked:'Untracked file "{{path}}" will be permanently deleted.',discard_confirm_message_all:"All unstaged changes to tracked files will be discarded, and untracked new files will be deleted. This cannot be undone.",rollback_confirm_title:"Rollback to this version?",rollback_confirm_message:'HEAD will move to commit "{{message}}" ({{hash}}). All changes after that commit will remain as unstaged working tree changes for you to review, stage, or commit.',rollback_warn_dirty:"You already have uncommitted changes. After rollback they will appear together with the changes from rolled-back commits.",rollback_warn_remote:"A remote is configured: {{count}} local commit(s) will be removed from the current branch. If they were pushed, you may need a force push later. Proceed with caution.",rollback_file_confirm_title:"Undo this commit's change to the file?",rollback_file_confirm_message:'Changes from commit