s_button:"保存修改",global_models_title:"全局默认模型",save_global_button:"保存全局配置",global_models_updated:"全局默认模型已更新",no_models_error:"当前没有任何可用模型，请先在「模型服务」中配置并启用供应供应商，然后获取模型。",summary_model_title:"记忆总结模型",summary_model_desc:"优化用于长文本摘要和记忆提取的系统模型，处理大段上下文时使用。",dialogue_model_title:"默认对话模型",dialogue_model_desc:"这是主要的智能分析和系统交互模型。当没有专门指定模型时，系统将默认使用它。",naming_model_title:"默认命名模型",naming_model_desc:"执行标题命名、短句提取等简单任务时使用的模型。建议使用响应快、成本低的轻量级模型。",embedding_model_title:"嵌入模型 (Embedding)",embedding_model_desc:"用于文本向量化的模型，支撑 RAG 语义搜索功能。如 text-embedding-3-small。如果列表为空，请先在供应商处获取并启用 Embedding 类型的模型。",tts_model_title:"TTS 语音合成",tts_model_desc:"用于将文本转换为语音的模型，支持朗读消息和语音播放功能。",no_models_fetch_first:"没有可用的模型，请先获取模型列表或确保有默认模型",test_model_empty:"测试模型 ID 不能为空",api_key_placeholder:"API Key",test_connection_title:"选择测试模型",test_connection_desc:"请选择要用来测试连接的大语言模型（对话模型）。不要选择 Embedding、Rerank 或 TTS 模型。",test_connection_help:"连接测试会调用对话接口。请在弹窗中选择大语言模型（对话模型），不要选择 Embedding、Rerank 或 TTS 模型。若列表为空，请先获取模型并启用对话模型。",no_chat_models_for_test:"没有可用于测试连接的大语言模型。请先获取模型列表，并启用对话模型（非 Embedding/TTS）。",test_model_not_chat:"请选择大语言模型进行连接测试，Embedding/TTS 模型不支持此测试。",save_failed:"保存失败: {{message}}",model_id:"Model ID",start_test:"开始测试",error_no_model:"检测失败：可能是未配置有效的 Embedding 模型或服务未连通。"},about:{title:"关于白守",app_name:"白守",developer_label:"开发者",dev_mode_hint:"再点 $count 次进入开发者模式",oss_license_label:"开源协议",visit_github:"访问 GitHub 仓库",copy_diagnostic_log:"复制诊断日志",copy_diagnostic_log_desc:"复制最近的应用日志，便于反馈闪退等问题。若刚发生闪退，请先重新打开 App 再复制。",copy_diagnostic_log_action:"复制到剪贴板",copy_diagnostic_log_success:"诊断日志已复制到剪贴板（{{count}} 字符）",copy_diagnostic_log_failed:"复制失败，请稍后重试",love_message:"🌸樱&晓 永远爱着Anson❤️"},updater:{section_title:"应用更新",current_version:"当前版本",latest_version:"最新版本",latest_unreleased:"暂未发布",not_released_toast:"尚未检测到已发布的安装包版本。开发环境下无法在线更新，请使用正式打包版本。",checking:"正在检查更新…",checking_short:"检查中…",available:"发现新版本 v{{version}}",downloading:"下载中 {{progress}}%",downloaded:"下载完成，可以安装",not_available:"已是最新版本",error:"检查更新失败",idle:"检查应用更新",view_release:"发布说明",download:"下载更新",install:"立即安装",check_again:"再次检查",retry:"重试",check:"检查更新",release_notes:"更新日志",auto_check:"自动检查更新",auto_check_desc:"启动应用时自动检查是否有新版本",view_github:"查看 GitHub 仓库"},developer:{title:"开发者选项",load_demo_data:"创建演示工作空间",load_demo_desc:"新建独立工作空间并写入 66 条日记与 17 篇总结（脱敏演示数据）",clear_all_data:"一键清除数据 (危险)",clear_all_desc:"清空本地存储、数据库和文件。",load_demo_success:"已创建演示工作空间「{{vaultName}}」",demo_vault_fallback:"演示空间",load_demo_failed:"❌ 创建失败: $e",clear_warning_title:"警告：一键清除数据",clear_warning_content:`此操作将极其危险的清除所有的保存配置、所有日记、所有总结、图片及数据库，并将软件恢复至出厂状态。

操作不可逆，强烈建议确认数据安全！

确认继续码？`,confirm_clear:"确认清除",clear_success_title:"清除成功",clear_success_content:"所有数据已全部清空。为使软件重新生效，请手动彻底重启应用。",clear_failed:"清除数据失败: $e",debug_title:"🛠 开发者调试",data_management:"数据管理",load_demo_full_desc:"将创建名为「演示空间」的新工作空间（重名则自动编号），切换至该空间并写入脱敏演示数据，不影响当前工作空间。",loading_status:"加载中...",clear_all_success:"所有核心数据与环境已抹除，点击确认重启容器以进入安全着陆模式。",clear_success:"清理完成",clear_agent_db_desc:"删除 Agent 会话、伙伴、消息数据（重启后自动重建）",clear_agent_db:"清理 Agent 数据库",clear_agent_success:"Agent 数据库碎片已清空并安全关闭连结，系统需硬重启进行热重建。",insert_compression_test:"注入压缩测试对话",insert_compression_test_desc:"新建一条含 15 轮的模拟 AI 对话（含工具调用）；数据规模按当前绑定伙伴的压缩阈值自动生成，用于测试滚动压缩。",insert_compression_test_success:"已创建压缩测试对话（{{rounds}} 轮，约 {{tokens}} tokens）",insert_compression_test_failed:"注入失败: ",open_onboarding:"预览开屏引导",open_onboarding_desc:"跳转到首次启动引导页，用于检查文案与排版（不会修改已有数据）。"},privacy:{title:"隐私政策与理念",data_ownership:"1. 数据主权",data_ownership_desc:"白守始终认为，记忆是灵魂的延伸。你的日记数据仅保存在本地 SQLite 数据库中。除了你主动配置的 AI 供应商和云同步目标外，白守不会以任何形式上传你的隐私。",local_first:"2. 本地优先",local_first_desc:"即便没有网络，你依然可以流畅地写日记。所有的 AI 总结都是在你发起请求时即时生成的，我们不存储任何生成的文本。",transparency:"3. 透明与安全",transparency_desc:"白守支持端到端的数据导出与同步。你可以随时通过 ZIP 导出彻底带走自己的回忆，或者将其同步至你完全掌控的 S3/WebDAV 空间。"},agent:JSON.parse('{"partner_label":"伙伴","no_model_selected":"暂未选择模型","start_new_conversation":"开始新的对话","start_conversation_hint":"在下方输入框随便说点什么，或者点击左侧发起新对话～","load_more_conversations":"加载更多对话","tools":{"built_in":"内置工具","community":"社区工具","community_coming_soon":"你将可以从社区安装和分享工具","tool_call":"工具调用","tool_call_results":"工具调用 · {{count}} 个结果","community_market_coming":"社区工具市场即将上线","diary_read":"日记读取","diary_read_desc":"通过精确的日期读取一篇或多篇日记的完整内容。支持一次最多读取 20 篇。如果您不知道确切日期，请先使用 diary_list 或 diary_search。","diary_edit":"日记编辑","diary_edit_desc":"修改已有的日记条目。调用前必须先用 diary_read 读取该日期的完整内容。默认模式为“追加 (append)”，系统会按日记格式模板自动插入时间标题块。使用“覆盖 (overwrite)”模式可以替换全部内容。标签将自动与现有标签合并。","diary_delete":"日记删除","diary_delete_desc":"删除特定的日记条目。这是破坏性操作且无法撤销。请务必在执行前进行确认。","diary_list":"日记列表","diary_list_desc":"列出指定日期范围内的所有日记条目（含起止日期）。返回包含日记条目的日期列表，以及每条日记的简短预览。使用此工具来了解用户在哪些天写过日记。","diary_search":"日记搜索","diary_search_desc":"通过关键词搜索用户的个人日记条目。返回匹配的日记日期和内容片段。当用户询问他们过去的经历、回忆或个人记录时使用此工具。\\n\\n涉及具体人名、地点、事件或日期且当前对话无明确依据时，必须先搜索再回答，禁止猜测或编造。\\n\\n重要提示：此工具仅搜索本地存储的用户个人日记条目，不搜索互联网。如需搜索互联网，请改用 web_search 工具。","diary_write":"日记写入","diary_write_desc":"在指定日期创建一篇新日记。如果该日期已存在日记，请改用 diary_edit。","summary_read":"总结读取","summary_read_desc":"读取 AI 生成的总结（周报、月报、季报或年鉴）。返回特定时间段的总结内容。如果需要原始日记条目，请改用 diary_list 或 diary_search。","message_search":"消息搜索","message_search_desc":"通过关键词在所有会话中搜索过去的对话消息。返回匹配的消息片段，包括会话标题和日期。当用户引用以前讨论过的内容，或者您需要召回以前的对话时非常有用。","vector_search":"语义搜索","vector_search_desc":"在对话历史和存储的记忆中进行语义搜索。当需要回忆当前上下文中未涵盖的过往内容时，可选用此工具。可按需通过 start_date / end_date（YYYY-MM-DD）限定搜索时间范围。返回语义相关的对话片段与评分。若滚动摘要或近期消息已足够回答，请直接基于上下文作答。","memory_store":"记忆存储","memory_store_desc":"将重要信息存储为长期记忆，以便以后进行语义搜索检索。当用户表达偏好、做出决定或您遇到值得记住的信息时，请使用此工具。存储的记忆将被向量化，并可以通过 vector_search 工具检索。","memory_delete":"记忆删除","memory_delete_desc":"通过语义搜索删除已存储的记忆。首先搜索与查询匹配的记忆，然后删除匹配的条目。当用户想要忘记某些内容或删除过时信息时使用此工具。重要提示：在删除记忆之前，请务必先与用户确认。","current_time":"当前时间","current_time_desc":"获取当前的真实世界时间、日期及星期。在回答与时间计算、年龄、绝对日期等相关的问题时非常有用。","compress_context_upstream":"上下文上行压缩","compress_context_upstream_desc":"在下次请求发送给模型之前，将较早对话合并为滚动摘要（上行）。","compress_context_downstream":"上下文下行压缩","compress_context_downstream_desc":"在助手回复落盘后更新摘要并剪枝过长工具输出（下行）。","web_search":"网络搜索","web_search_desc":"在互联网上搜索最新信息、新闻和实时数据。当用户询问近期事件、当前事实或任何超出您训练数据且需要最新信息的内容时，可选用此工具。\\n\\n重要提示：此工具仅搜索公共互联网，请勿用于搜索用户的个人日记，搜索个人日记请使用 diary_search。\\n\\n可提供 2-3 个不同角度或关键词的搜索查询以获得更全面的结果。例如，如果用户询问“iPhone 16 对比三星 S25”，您可以搜索 [\\"iPhone 16 specs review\\", \\"Samsung S25 specs review\\", \\"iPhone 16 vs Samsung S25 comparison\\"]。\\n\\n结果中会包含可点击的 [标题](url) 引用，您可以使用 url_read 工具来详细阅读特定的页面。","web_search_not_enabled":"您还未启用网络搜索，请在工具栏开启后重试。","param_max_results":"搜索结果上限","param_max_results_desc":"AI 每次搜索时返回的最大结果数量","param_max_results_tooltip":"限制单次日记搜索最多返回多少条结果。","diary_read_tooltip":"让伙伴按日期读取日记全文，一次最多 20 篇；需传入日期参数（不知道日期时先用「日记列表」或「日记搜索」）。","diary_edit_tooltip":"修改已有日记，可追加带时间戳的内容，或整篇覆盖。","diary_delete_tooltip":"永久删除指定日期的日记，不可恢复。","diary_list_tooltip":"按日期范围列出有日记的日期，并附带简短预览。","diary_search_tooltip":"在本地个人日记中按关键词搜索（不搜索互联网）。","summary_read_tooltip":"读取 AI 生成的周/月/季/年总结。","message_search_tooltip":"按关键词搜索历史会话中的消息。","memory_store_tooltip":"将重要信息写入长期记忆，供后续语义召回。","memory_delete_tooltip":"删除已存储的记忆，操作前请先与用户确认。","auto_inject_time":"当前时间","auto_inject_time_desc":"每次自动注入当前时间","auto_inject_time_tooltip":"开启后，每次对话会在系统上下文中自动注入当前日期与时间；关闭后伙伴不会默认获知当前时间，需要时可调用 current_time 工具。","param_search_engine":"搜索引擎","param_search_engine_desc":"选择用于网络搜索的引擎","url_read":"网页读取","param_max_length":"内容长度上限","param_max_length_desc":"网页读取时返回的最大字符数","param_rag_enabled":"RAG 向量压缩","param_rag_enabled_desc":"启用后搜索结果将通过向量检索筛选最相关内容（需配置嵌入模型）","param_rag_max_chunks":"引用片段总数上限","param_rag_max_chunks_desc":"最大提取并交付给 AI 供参考的片段总数，决定了 Token 消耗的上限","param_rag_chunks_per_source":"来源片段上限","param_rag_chunks_per_source_desc":"单一网站最多能够提取的片段数量，防止被某个长文网站刷屏","param_plain_snippet_length":"无向量模型时的截取长度","param_plain_snippet_length_desc":"当并未配置 Embedding 模型时，系统退化为直接拼接待查文本。为了避免消耗过多 Token，将在此字数后对单网站截断","param_tavily_api_key":"Tavily API Key","param_tavily_api_key_desc":"Tavily 搜索 API Key（https://app.tavily.com 免费获取）","param_exa_api_key":"Exa API Key","param_exa_api_key_desc":"Exa 搜索 API Key（https://dashboard.exa.ai/api-keys 获取）","param_anysearch_api_key":"AnySearch API Key","param_anysearch_api_key_desc":"AnySearch 搜索 API Key（https://www.anysearch.com/console/api-keys 免费获取）","shortcuts":{"translate_name":"翻译","translate_content":"请把下面这段话信达雅地翻译为中文（含专业术语解释）：\\n\\n","summarize_name":"总结","summarize_content":"请总结以下内容背后的核心要义：\\n\\n"},"url_read_desc":"直接读取特定网页 URL 的文本内容。当您有想要分析或总结的特定链接时使用此工具，而不是搜索整个网络。"},"chat":{"companion_mode":"深度陪伴","empty_hint":"试试问：「我这周写了什么日记？」","input_system_prompt_hint":"输入自定义伙伴行为准则 (如：用简短的中文回答)","retry":"重试","resend":"重新发送","thinking_time":"思考中 {{time}}","thought_time":"思考耗时 {{time}}","compression_thought_time":"总结思考耗时 {{time}}","compression_summary_time":"生成摘要耗时 {{time}}","thought_process":"思考过程","thinking":"思考中...","thought_process_prefix":"思考过程","branch":"从此处创建分支","branch_success":"分支创建成功","branch_failed":"分支创建失败","err_format":"请求格式错误，请检查消息内容后重试","err_unauthorized":"API Key 无效或无权限访问此模型","err_too_many_requests":"请求过于频繁，请稍后重试","err_server":"服务器暂时不可用，请稍后重试","err_timeout":"请求超时，请检查网络连接后重试","err_network":"无法连接到服务器，请检查网络设置","start_chat":"开始和伙伴对话","session_settings":"会话设置","session_name":"会话名称","system_prompt_label":"行为准则 (System Prompt)","you_label":"你","ai_label":"AI 伙伴","regenerate":"重新生成","copy":"复制","input_hint":"输入消息...","err_no_model":"请先在设置中配置 AI 模型","cost_detail_title":"当前计费","cost_total":"消耗总计","cost_disclaimer":"费用仅供参考，请以官方为准。","context_chain":"上下文消息","tab_context":"上下文","tab_compressed":"压缩内容","tab_original":"原文","tab_prompt":"提示词","cost_cumulative_title":"累计 API 消耗","cost_cumulative_total":"累计费用","cost_cumulative_input":"累计输入","cost_cumulative_output":"累计输出","cost_cumulative_cache_read":"缓存读取","cost_cumulative_cache_write":"缓存写入","cost_context_title":"当前上下文","cost_context_size":"上下文大小","cost_no_data":"暂无数据","tokens_unit":"tokens","round_input":"上行","round_output":"下行","round_cache_read":"缓存读","round_cache_write":"缓存写","cache_read":"缓存读取","cache_write":"缓存写入","cache_label":"缓存：","cache_read_short":"缓存","cache_write_short":"缓存写","round_cost":"费用","full_call_chain":"完整调用链","tab_call_chain":"调用链","next_request_estimate":"下次请求预计","compression_help_aria":"查看对话压缩规则说明","compression_help_modal_title":"对话压缩规则","compression_help_intro":"当对话上下文超过伙伴设置的 Token 阈值时，系统会把更早的对话合并为一条「对话压缩」摘要，再与近期完整轮次一起发给模型。","compression_help_trigger_title":"何时触发","compression_help_trigger_body":"在伙伴设置中开启「自动压缩」并设定阈值（0 表示关闭）。每次发送前与回复落盘后都会检测；超过阈值则调用模型生成/更新摘要，并剪枝过长的工具输出。","compression_help_chain_title":"调用链展示顺序","compression_help_chain_1":"系统提示词（独立一块）","compression_help_chain_2":"对话压缩（独立一块，介于轮次之间）","compression_help_chain_3":"第 1、2… 轮：仅压缩点之后的对话，从第 1 轮重新计数","compression_help_footer_title":"底部指标含义","compression_help_footer_tokens":"上下文 tokens：系统提示词 + 压缩摘要 + 当前窗口内消息的粗估总量","compression_help_footer_rounds":"上下文轮数：压缩后计入窗口的用户轮数 / 伙伴配置的携带轮数上限（不限表示不按轮截断）","compression_help_keep_title":"保留轮数","compression_help_keep_body":"压缩时始终保留最近 N 轮用户消息的完整原文（含该轮 AI 回复与工具调用）；更早内容进入摘要。N 在伙伴设置中配置。","compression_help_branch_title":"分支与回到更早位置","compression_help_branch_body":"创建分支会复制消息与仍有效的压缩快照。在某条较早消息上重发/编辑重发时，若锚点消息被删除，将回退为完整原文上下文而非摘要。","compaction_summary":"对话压缩","compaction_between_rounds":"已压缩更早轮次，以下从第 1 轮重新计数","compressing_context":"正在压缩对话…","compressing_context_hint":"较早的消息正在合并为摘要，完成后可继续对话","compression_divider":"对话已压缩","compression_divider_aria":"对话已压缩分界","compression_stream_waiting":"等待模型输出…","recompress_btn":"重新压缩","recompress_running":"压缩中…","recompress_completed":"重新压缩完成","compression_completed":"对话压缩完成","compression_thinking":"压缩思考中…","compression_thought":"压缩思考过程","compression_thinking_waiting":"等待压缩模型思考…","recompress_hint":"按上次压缩触发时的消息范围，重新生成对话摘要","recompress_banner_hint":"正在重新生成对话摘要，可切换条目或切换页面，完成后会自动更新","recompress_range_hint":"选择要纳入摘要的对话轮次（压缩点之前的完整轮次），将发送给模型生成新摘要。","recompress_from":"从第","recompress_to":"轮 至 第","recompress_round_suffix":"轮","recompress_merge_prior":"合并当前摘要后再归纳","recompress_submit":"开始压缩","recompress_failed":"重新压缩失败","recompress_not_enough_messages":"压缩区间内消息不足（可能快照锚点与历史不一致），请尝试重新对话后再压缩","est_context_tokens":"上下文","context_rounds":"上下文轮数","context_rounds_unlimited":"不限","round_label":"第 {{n}} 轮","current_round":"当前","round_items":" 条","this_round_usage":"本轮消耗","resize_panel":"拖动调整宽度","no_context_messages":"暂无发送给 AI 的上下文记录","select_chain_item":"在左侧选择一条消息，查看发送给 AI 的完整内容","pricing_table_title":"价格表信息","pricing_last_updated":"最后更新","pricing_source":"价格数据源","pricing_source_tooltip":"点击在外部浏览器中查看原始 API 价格数据","pricing_refresh":"刷新","pricing_refreshing":"刷新中...","pricing_refresh_failed":"刷新价格表失败","pricing_refresh_network_error":"网络错误，请检查网络连接","pricing_unknown":"未知","pricing_boot_load_failed":"未能拉取 models.dev 价格表，计费估算可能不准确，请检查网络后在计费面板中刷新","pricing_just_now":"刚刚","pricing_minutes_ago":"$count 分钟前","pricing_hours_ago":"$count 小时前","role_system":"📋 系统","role_user":"用户","role_assistant":"✨ 助手","role_tool":"🔧 工具","empty_content":"(空)","no_content":"(无内容)","search_emoji":"搜索 Emoji...","select_partner":"选择伙伴","manage":"管理","recent_chats":"最近对话","select_all":"全选","deselect_all":"取消全选","delete_confirm_multi":"确定删除 $count 个对话？此操作不可撤销。","delete_count":"删除 ($count)","chat_count":"$count 个对话","new_chat_label":"新对话","collapse_sidebar":"收起侧边栏","expand_sidebar":"展开侧边栏","assistant_init_failed":"伙伴初始化失败: $e","search_recent":"搜索近期对话...","no_search_results":"无匹配的搜索结果","load_more":"加载更多","manage_pinned":"管理固定伙伴","delete_msg_confirm":"您确定要删除这条消息历史吗？此操作不可逆转。","scroll_to_bottom":"回到最新消息","cancel_select_all":"取消全选","memory":"AI 记忆","reasoning":"思考中...","using_tool":"AI 核心协议激活并流转中","readAloud":"语音朗读","tts_off":"语音关闭","tts_always":"始终朗读","tts_manual":"手动朗读","tts_no_api":"TTS 功能不可用","tts_not_configured":"TTS 模型未配置，请在设置中配置 TTS 模型","tts_provider_not_found":"TTS 提供商未找到","tts_api_error":"TTS API 请求失败","tts_failed":"语音合成失败"},"sessions":{"history":"对话历史","settings":"伙伴设置","new_chat":"新对话","companion_tab":"深度陪伴","session_tab":"会话模式","companion_title":"深度陪伴模式","companion_desc":"不需要管理会话，直接开始聊天","continue_chat":"继续对话","no_history":"还没有对话记录","start_new":"开始新对话","delete_title":"删除对话","delete_confirm":"确定删除\\"{title}\\"？","delete_btn":"删除","companion_switch":"伴侣模式","companion_on":"已开启 — 单一持续对话，无会话概念","companion_off":"已关闭 — 多会话模式","memory_window":"上下文轮数","memory_window_desc":"发送最近 {count} 条消息给模型","persona":"角色人设","persona_hint":"描述伙伴的身份和风格","behavior":"行为准则","behavior_hint":"描述伙伴需要遵守的规则","rename":"重命名","rename_hint":"输入新会话名称","actions":"操作","pin":"置顶对话","unpin":"取消置顶","delete_session":"删除对话","default_title":"新对话","unnamed_session":"未命名会话","companion_session_title":"伴侣模式","total_count":"会话总数","total_messages":"总消息数","active_agents":"活跃伙伴数","management_title":"会话管理","batch_manage":"批量管理","pinned_only":"已置顶 📌","empty":"暂无会话记录...","groupPinned":"已置顶","groupToday":"今天","groupYesterday":"昨天","groupWeek":"近 7 天","groupOlder":"更早","newChat":"发 起 超 链","noResults":"一片虚无..."},"rag":{"title":"RAG 记忆管理","search_hint":"搜索记忆内容...","clear_all":"清空","clear_all_title":"清空所有记忆","clear_all_content":"确定要删除所有已嵌入的向量数据吗？此操作不可撤销。","clear_confirm":"确认清空","delete_tooltip":"删除","stat_total":"总条目","stat_model":"模型","stat_dimension":"维度","rag_disabled_hint":"全局记忆已关闭，伙伴将不会使用RAG检索","dimension_detected":"自动检测: ${dimension}维","dimension_detecting":"正在检测...","dimension_click_detect":"点击检测维度","dimension_not_configured":"未配置Embedding模型","detect_success":"检测成功：${dimension}维","detect_failed":"检测失败，请检查模型配置","detect_error":"检测失败: $error","clear_dim_title":"清空当前维度向量","clear_dim_content":"确定要删除所有 ${dimension} 维的向量数据吗？\\n其他维度的数据不受影响。","clear_dim_confirm":"确定删除","clear_dim_no_config":"当前未配置维度，无法清空","clear_dim_success":"已删除 $deleted 条 ${dimension}维 向量数据","batch_embed_title":"全量嵌入日记","batch_embed_content":"将读取所有日记内容并生成向量嵌入。\\n已存在的日记不会重复嵌入。\\n过程可能需要一些时间。","batch_embed_start":"开始嵌入","batch_embed_progress":"嵌入中 $progress/$total","batch_embed_success":"完成！已嵌入 $count 篇日记","batch_embed_error":"批量嵌入出错: $error","embedding_not_configured":"请先配置 Embedding 模型","no_memories_yet":"还没有记忆数据","no_memories_match":"未找到匹配的记忆","memories_auto_hint":"与 Agent 对话后，记忆会自动存储到这里","action_clear_dimension":"清空当前维度","action_batch_embed":"全量嵌入日记","action_add_memory":"手动添加记忆","add_memory_title":"添加记忆","add_memory_hint":"输入要记住的内容...","add_memory_save":"保存","add_memory_success":"记忆已保存并嵌入","edit_memory_title":"编辑记忆","edit_memory_success":"记忆已更新并重新嵌入","retrieval_params":"检索参数调节","similarity_threshold":"相似度阈值","migration_pending_title":"检测到未完成的迁移","migration_pending_content":"上次嵌入模型迁移未完成（可能是应用异常退出）。\\n\\n是否继续迁移？备份数据仍然安全。","migration_mismatch_title":"发现异构记忆模型","migration_mismatch_content":"当前工作区的已有记忆使用的是其他版本的嵌入模型。\\n这会导致旧记忆由于底层维度不匹配而完全无法被 AI 检索到。\\n\\n是否一键迁移统一至全局最新的模型配置？（点击【暂不处理】你仍然可以在 RAG 页面随时手动点此操作）","migration_later":"稍后再说","migration_continue":"继续迁移","migration_error":"迁移出错: $error","migration_model_changed_title":"嵌入模型已更换","migration_model_changed_content":"检测到您更换了嵌入模型。\\n\\n旧的向量数据与新模型维度不兼容，需要重新嵌入所有数据。\\n\\n此操作会：\\n• 备份现有文本元数据\\n• 清空旧向量并用新模型重新嵌入\\n• 完成后自动校验数据完整性\\n\\n过程在后台异步执行，不影响正常使用。","migration_start_now":"立即重新嵌入","migration_preparing":"正在准备重新嵌入...","migration_switch_warning_title":"更换嵌入模型？","migration_switch_warning_content":"新模型可能与现有向量不兼容，更换后将在后台重新嵌入日记数据。是否继续？"},"assistant":{"management_title":"伙伴管理","create_title":"创建伙伴","edit_title":"编辑伙伴","name_label":"伙伴名称","name_hint":"输入名称","search_hint":"搜索伙伴...","name_required":"请输入伙伴名称","partner_info_label":"伙伴信息","prompt_label":"系统提示词","prompt_hint":"定义伙伴的角色、行为和回复风格...","context_window_label":"上下文轮数","context_window_desc":"发送给模型的最近对话轮数。一轮以你的消息开始，包含 AI 的回复以及该轮内的工具调用；轮数越多记忆越长，但 Token 消耗也更高。","set_default":"设为默认","set_default_desc":"新建对话时自动使用此伙伴","default_label":"默认","no_prompt":"未设置提示词","empty_hint":"还没有伙伴，创建一个吧","create_first":"创建第一个伙伴","remove_avatar":"移除头像","delete_confirm_title":"删除伙伴","delete_confirm_content":"确定要删除此伙伴吗？关联的对话及附件将会被一并删除。","settings_entry":"伙伴管理","select_title":"选择伙伴","clear_selection":"清除","default_tag":"默认","no_assistant":"无伙伴","pin_to_sidebar":"置顶并显示在侧边栏","unpin_from_sidebar":"取消侧边栏固定","select_builtin_avatar":"内置头像","avatar_choice_title":"选择头像","builtin_avatars":"内置头像","upload_avatar":"上传","reset_builtin_avatar":"恢复默认","description_label":"简介","description_hint":"简短描述伙伴的用途...","context_unlimited":"∞ 无限","context_limited":"有限","context_unlimited_desc":"不限制轮数，将发送全部对话历史（每轮含你的消息、AI 回复及工具调用）给模型。","bind_model_label":"绑定模型","use_global_model":"使用全局模型","select_model_label":"选择模型（使用全局默认）","bind_model_desc":"绑定后，和伙伴创建对话时，会默认优先使用选择的模型","select_model_title":"选择模型","compress_label":"自动压缩","compress_disabled_desc":"对话不会自动压缩，所有消息将完整保留","compress_enabled_desc":"对话超过阈值时自动将旧消息压缩为摘要","compress_tooltip":"当对话上下文超过设定的 Token 阈值时，系统会自动压缩早期对话内容，保留最近的对话轮数。","compress_token_threshold_label":"Token 阈值","compress_keep_turns_label":"保留互动轮数","compress_keep_turns_unit":"$count 轮","compress_keep_turns_desc":"触发压缩时，保留最近若干轮完整原文。一轮以你的消息开始，包含 AI 回复及该轮内的工具调用；更早的轮次会被压缩为摘要。","compress_keep_turns_tooltip":"触发压缩时，按设定轮数保留最近对话的完整原文（含每轮内的工具调用），以保证上下文连贯。","compress_system_prompt_label":"压缩提示词","compress_system_prompt_desc":"生成对话压缩摘要时发给模型的系统指令。可点击「恢复默认」按当前界面语言载入内置默认稿。","compress_system_prompt_reset":"恢复默认","default_assistant_name":"Latte","default_assistant_desc":"古老的吸血鬼贵族，永恒的记忆守护者，白守的看板娘。","keep_one_error":"至少保留一个伙伴","new_name_prompt":"请输入新的伙伴名称：","edit_name_title":"修改伙伴名称","unpin":"取消置顶","window_size":"窗口大小","delete_confirm_desc":"此操作将永久删除该伙伴的所有配置，该操作不可恢复。","title":"伙伴管理","create_new":"新增伙伴","create":"新建伙伴","current":"当前","memory_label":"记忆","current_partner":"当前伙伴","delete_confirm":"是否确认删除该伙伴？","picker_no_selection":"选择一个伙伴查看详情","click_to_rename":"点击修改名称","not_found":"伙伴未找到","created":"伙伴已创建","updated":"伙伴已更新","deleted":"伙伴已删除","kind_companion":"亲密伙伴","kind_work":"工作伙伴","kind_companion_description":"可编辑日记、检索 RAG 记忆，适合日常陪伴与记录生活。","kind_work_description":"仅用于知识查询与工作协助，无法读写日记或访问记忆库。"},"provider":{"add_title":"新增 AI 供应商","add_type_label":"供应商类型 (Client)","add_name_label":"供应商名称","add_name_hint":"例如: My OpenAI Proxy","add_button":"添加","delete_title":"删除供应商","delete_confirm":"确定要删除\\"$name\\"吗？","delete_button":"删除","delete_tooltip":"删除供应商","custom_tag":"自定义"},"profile":{"default_nickname":"白守用户","no_nickname":"未设置昵称","edit_nickname":"修改昵称","edit_nickname_prompt":"请输入新的昵称："},"recall":{"title":"唤醒回忆","tab_diary":"日记档案","tab_memory":"向量记忆","search_hint":"检索关键字","no_results":"未在库中匹配到任何历史记忆碎片。","search_timeout":"语义搜索超时，请稍后重试","selected":"已选择","inject":"提取至当前上下文对话"},"error":{"api_key":"API Key 已过期或无效，请转至模型设置中更新您的密钥。","rate_limit":"请求过于频繁或超出并发限制，请稍后再试。","network":"网络连接失败，请检查您的网络连接或代理设置。","timeout":"请求响应超时，请重试。","quota":"模型服务商提示账号额度不足。","unknown":"出错了：{{msg}}","create_session":"由于系统原因创建会话失败: {{msg}}","vision_not_supported":"当前模型不支持图片识别哦，可以换成视觉模型再试试呢~"},"generation_failed":"回复生成失败","stream_cancelled":"取消成功","trace_title":"调用追踪 [{{modelId}}]","default_assistant_name":"Latte","default_assistant_prompt":"你是 Latte（拉提），白守 App 的专属 AI 伙伴。","default_assistant_desc":"古老的吸血鬼贵族，永恒的记忆守护者，白守的看板娘。","delete_session_confirm":"您确定要永久删除这篇对话吗？此操作不可逆转。","batch_delete_confirm":"您确定要删除选中的 {{count}} 篇对话吗？此操作不可逆转。","renamed_toast":"已重命名为「{{title}}」","rename_session":"重命名对话","sidebar":{"expand":"展开侧边栏","collapse":"折叠侧边栏","pin_hint":"这里可以置顶伙伴","recent_chats":"最近对话","search_hint":"搜索近期聊天...","no_recent_chats":"暂无近期对话，快点开始一个吧~"},"switchModel":"切换模型","noMatchModel":"未发现可搭载的模型","manageProviders":"管理模型与供应商"}'),input:{upload_attachment:"上传附件",attachment_source_title:"选择附件来源",attachment_camera:"拍照",attachment_photo_library:"相册",attachment_file_manager:"文件管理",attachment_permission_denied:"需要相机或相册权限才能继续",shortcut_command:"快捷指令",vision_not_supported_warn:"当前选中的模型不支持图片识别，建议更换为支持多模态的模型（如 gpt-4o, gemini-1.5）以获得最佳效果。",model_no_vision_hint:"当前模型可能不支持图片，建议切换至支持多模态的模型",file_too_large:"文件大小超过限制 (最大 512KB)"},shortcut:{label_name:"指令名称",label_hint:"例如：翻译",command_label:"指令命令 (用于触发)",command_hint:"例如: review, translate",content_prompt:"对应内容",content_hint:"请帮我翻译下面这段文本。",default_tag:"指令",title:"快捷指令",no_match:"找不到任何匹配的快捷指令",search_placeholder:"搜索快捷指令...",drag_sort_hint:"点击左侧箭头调整顺序",move_up:"上移",move_down:"下移",drag_handle:"拖动排序",add_short:"新增",no_shortcuts_hint:"暂无任何快捷指令，立即创建一个吧。",delete_confirm:"确定删除这条快捷指令吗？",duplicate_command:"已存在相同快捷短语的指令，请换一个短语",input_slash_hint:"在空输入框输入 / 可快速匹配快捷指令；继续输入可过滤，按回车或点击条目即可插入正文。",manager_title:"快捷指令管理",add_custom_command:"新增自定义指令",back:"返回",edit:"编辑"},models:{tts:{advanced_title:"语音合成 (TTS) 高级设置",voice_label:"发音人角色 (Voice ID)",voice_placeholder:"例如 alloy, echo, Mia, 冰糖 等",voice_hint:"请输入您当前 TTS 模型所支持的具体发音人/音色 ID。例如 OpenAI 默认可用 alloy，小米 TTS 可填写 冰糖、Mia 等。",speed_label:"语速比例 (Speed)",format_label:"返回格式 (Format)"},click_to_assign:"点击分配默认处理模型",routing_desc:"允许为您日常面对的不同维度的复杂任务，挂载不同的专长模型。",switch_model:"切换模型",vision_supported:"支持视觉多模态"},dashboard:{greeting:"又见面了，今天过得怎样？",shared_memory_desc:"调整回溯月份，为 RAG 或大语言模型导出近期总结上下文片段。",lookback_months:"回溯 {{count}} 个月",copy_to_ai:"Copy 给 AI"},chat:{send_to:"发给 {{name}}...",new_session:"新对话",pinned:"已固定",respond_to_message:"回应此