anges. Leaving will discard them.",exit_without_saving_confirm:"Exit without saving",editor_tag_placeholder:"Press Enter to add a tag...",date_format_editor_title:"{{year}}-{{month}}-{{day}} {{weekday}}",edit_summary:"Edit Summary",editor_leave_confirm:"You have unsaved content. If you exit now, your changes will be lost. Are you sure you want to discard and leave?",delete_success:"Diary deleted",delete_failed:"Delete failed",delete_warning:"Are you sure you want to permanently delete this diary? This action cannot be undone.",export_success:"Export successful",export_failed:"Export failed",export_markdown:"Export Markdown",filter:"Filter",filter_favorite:"Favorites",filter_weather:"Weather",filter_mood:"Mood",clear_filter:"Clear",weather_label:"Weather",weather:{default:"Weather",sunny:"Sunny",cloudy:"Cloudy",overcast:"Overcast",light_rain:"Light Rain",heavy_rain:"Heavy Rain",snow:"Snow",fog:"Fog",windy:"Windy"},mood_label:"Mood",mood:{default:"Mood",happy:"Happy",satisfied:"Satisfied",calm:"Calm",excited:"Excited",grateful:"Grateful",thoughtful:"Thoughtful",sad:"Sad",anxious:"Anxious",radiant:"Radiant"},location_placeholder:"📍 Location",unfavorite:"Unfavorite",favorite:"Favorite",table_menu:{sort_asc_row:"Sort by row (A-Z)",sort_asc_column:"Sort by column (A-Z)",sort_desc_row:"Sort by row (Z-A)",sort_desc_column:"Sort by column (Z-A)",align_none:"Align none",align_left:"Align left",align_center:"Align center",align_right:"Align right",add_row_above:"Add row above",add_column_before:"Add column before",add_row_below:"Add row below",add_column_after:"Add column after",move_row_up:"Move row up",move_column_left:"Move column left",move_row_down:"Move row down",move_column_right:"Move column right",duplicate_row:"Duplicate row",duplicate_column:"Duplicate column",clear_row:"Clear row",clear_column:"Clear column",delete_row:"Delete row",delete_column:"Delete column"},weekday_sun:"Sun",weekday_mon:"Mon",weekday_tue:"Tue",weekday_wed:"Wed",weekday_thu:"Thu",weekday_fri:"Fri",weekday_sat:"Sat",month_jan:"January",month_feb:"February",month_mar:"March",month_apr:"April",month_may:"May",month_jun:"June",month_jul:"July",month_aug:"August",month_sep:"September",month_oct:"October",month_nov:"November",month_dec:"December",month_suffix:"",jump_to_page:"Go to",pagination_info:"$total items, page $page / $pages",per_page:"/ page"},summary:{shared_memory_tooltip:"Aggregates and filters diaries and summaries by year, quarter, month, and week based on the selected lookback range (months), generating a clean context for AI retrieval.",dashboard_title:"Memories",lookback_period:"Past $months Months",collective_memories_title:"Memories",copy_memories:"Copy Collective Memory",copy_preview_title:"Copy will include",copy_preview_loading:"Counting items to copy…",copy_preview_diary:"Diaries",copy_preview_yearly:"Yearly summaries",copy_preview_quarterly:"Quarterly summaries",copy_preview_monthly:"Monthly summaries",copy_preview_weekly:"Weekly summaries",copy_preview_unit:"",copy_preview_total:"{{count}} item(s) in total",copy_preview_empty:"Nothing to copy in the current lookback range",algorithm_desc:"Based on the BaiShou cascade folding algorithm, redundent data is automatically filtered to build our collective memory context.",stats_yearly:"Yearly",stats_quarterly:"Quarterly",stats_monthly:"Monthly",stats_weekly:"Weekly",stats_daily:"Daily",tab_weekly:"Weekly",tab_monthly:"Monthly",tab_quarterly:"Quarterly",tab_yearly:"Yearly",toast_copied:"Collective memory copied to clipboard",copy_prefix_label:"Copy Prefix",copy_prefix_hint:"Automatically added to the front of copied content (e.g., Hi, these are my memories...)",cascade_folding_title:"Memory Folding Rules",cascade_folding_content:`To provide the AI with the most efficient memory context, BaiShou uses a 'Cascade Folding' algorithm:

1. Overlap Mechanism: If a Monthly or Quarterly report has been generated for a period, the system assumes the AI already understands the macro-context of that time, so it folds (hides) original diary entries from that period in the shared memory.
2. Progressive Detail: The system prioritizes keeping detailed diaries from the most recent weeks, while older memories are presented through higher-dimensional forms like Weekly, Monthly, or Quarterly reports.
3. Distillation vs Redundancy: This ensures that within limited Token constraints, the AI can see both recent details and the big picture without getting bogged down in an overwhelming sea of raw diary entries.`,range_selector:"Statistic Range",load_data:"Load Data",loading:"Loading data...",error_select_range:"Please select a date range first",no_data_range:"No diary data found in this range",raw_data_desc:"Lossless export of all diary data within a range, including metadata and tags.",tap_to_select_range:"Tap to select date range",raw_data_tab:"Raw Data",history_tab:"Archives",raw_data_title:"Raw Data Export",lookback_folded:"Collective Memories (Past $months months - Folded by Algorithm)",raw_data_range_label:"Range: ",raw_data_total_label:"Total: ",export_and_copy:"Export and Copy",toast_raw_exported:"Raw data copied to clipboard",export_failed:"Export failed",confirm_delete_summary:"Are you sure you want to delete this summary? Original diary data will not be affected.",delete_summary_title:"Delete Summary?",filter_month:"Filter Month",filter_year:"Filter Year",all_yearly:"All Yearbooks",content_label:"Summary Content",time_range_label:"Time Range",generate_all:"Generate All",stop_generating:"Stop Generating",stopping:"Stopping...",concurrency_limit:"Concurrency Limit",concurrency_count:"Concurrency: $count",add_summary_title:"Add $type",paste_hint:"Paste AI generated summary here...",input_content:"Please enter content",added_success:"Added successfully",add_failed:"Failed to add",no_summary_type:"No $type yet",delete_confirm:'Are you sure you want to delete the summary for "$title"? This action cannot be undone.',deleted_success:"Deleted",click_to_generate:"Click top right to generate",title_weekly:"Weekly ($range)",title_monthly:"Monthly Report ($year-$month)",title_quarterly:"$year Q$q Quarterly Summary",title_yearly:"$year Yearly Summary",ai_suggestions:"AI Suggestions",detect_missing:"Re-detect",detecting_missing:"Detecting...",suggestion_generate:"Sugges