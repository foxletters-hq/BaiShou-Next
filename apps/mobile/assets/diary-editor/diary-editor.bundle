_style_prompt_label:"Style Instruction (optional)",mimo_style_prompt_placeholder:"e.g. light and natural tone, slightly faster pace",mimo_style_prompt_hint:"Control tone, emotion, and rhythm in natural language; leave empty for default style",pick_ref_audio_button:"Choose Reference Audio",pick_ref_audio_again_button:"Choose Again",ref_audio_path_label:"Reference Audio Path (refAudioPath)",ref_audio_path_placeholder:"Required, e.g. D:\\audio\\prompt.wav",prompt_text_label:"Reference Audio Text (promptText)",prompt_text_placeholder:"Required: spoken text in the reference audio",prompt_lang_label:"Reference Audio Language (promptLang)",text_lang_label:"Synthesis Text Language (textLang)",lang_zh:"Chinese (zh)",lang_en:"English (en)",lang_ja:"Japanese (ja)",lang_ko:"Korean (ko)",lang_yue:"Cantonese (yue)",speed_label:"Speed",format_label:"Audio Format",test_label:"Test TTS",test_placeholder:"Enter test text",test_default:"Hi, I'm Latte. How's your day going?",testing:"Testing...",test_button:"Test"}}},cj={ai_prompt:{context_title:"共同の思い出 (過去 $months ヶ月 - 白守アルゴリズムにより折り畳み済み)",prefix_yearly:"👑 年間",prefix_quarterly:"🏆 四半期",prefix_monthly:"🌙 月間",prefix_weekly:"📆 週間",prefix_diary:"📝 日記",raw_diary_data:"### 原始日記データ ($start ～ $end)",raw_weekly_data:"### 原始週間データ ($start)",weekly_label:"週記",raw_monthly_data:"### 原始月間データ ($year Q$q)",monthly_label:"月報",raw_quarterly_data:"### 原始四半期まとめデータ ($year年)",summary_label:"まとめ",raw_diary_data_monthly:"### 原始日記データ（全月分） ($year年$month月)",quarterly_weeklies_section:"### 今四半期の週記",quarterly_monthlies_section:"### 今四半期の月報",monthly_weeklies_section:"### 今月の週記",yearly_weeklies_section:"### 今年度の週記",yearly_monthlies_section:"### 今年度の月報",yearly_quarterlies_section:"### 今年度の四半期報",raw_data_export_title:"# 原始データエクスポート",export_range:"範囲: $start ～ $end",total_diaries_count:"合計: $count 篇の日記"},common:{save:"保存",cancel:"キャンセル",delete:"削除",edit:"編集",export:"エクスポート",confirm:"確定",refresh:"更新",loading:"読み込み中...",success:"成功しました",ok:"OK",saving:"保存中...",retry:"再試行",