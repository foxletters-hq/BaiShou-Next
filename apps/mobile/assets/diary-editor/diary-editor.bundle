ndy:"风"},mood_label:"心情",mood:{default:"心情",happy:"开心",satisfied:"满足",calm:"平静",excited:"兴奋",grateful:"感恩",thoughtful:"沉思",sad:"忧伤",anxious:"焦虑",radiant:"灿烂"},location_placeholder:"📍 位置",unfavorite:"取消收藏",favorite:"收藏",table_menu:{sort_asc_row:"按行排序 (A-Z)",sort_asc_column:"按列排序 (A-Z)",sort_desc_row:"按行排序 (Z-A)",sort_desc_column:"按列排序 (Z-A)",align_none:"取消对齐",align_left:"左对齐",align_center:"居中对齐",align_right:"右对齐",add_row_above:"在上方插入行",add_column_before:"在左侧插入列",add_row_below:"在下方插入行",add_column_after:"在右侧插入列",move_row_up:"上移行",move_column_left:"左移列",move_row_down:"下移行",move_column_right:"右移列",duplicate_row:"复制行",duplicate_column:"复制列",clear_row:"清空行",clear_column:"清空列",delete_row:"删除行",delete_column:"删除列"},weekday_sun:"周日",weekday_mon:"周一",weekday_tue:"周二",weekday_wed:"周三",weekday_thu:"周四",weekday_fri:"周五",weekday_sat:"周六",month_jan:"一月",month_feb:"二月",month_mar:"三月",month_apr:"四月",month_may:"五月",month_jun:"六月",month_jul:"七月",month_aug:"八月",month_sep:"九月",month_oct:"十月",month_nov:"十一月",month_dec:"十二月",month_suffix:"月",jump_to_page:"跳转",pagination_info:"共 $total 条，第 $page / $pages 页",per_page:"条/页"},summary:{shared_memory_tooltip:"根据所选的回溯范围（月），按年度、季度、月度和周度自动聚合并过滤日记与总结，生成纯净的上下文片段供 AI 检索。",dashboard_title:"回忆",lookback_period:"过去 $months 个月",collective_memories_title:"回忆",copy_memories:"复制共同回忆",copy_preview_title:"复制将包含",copy_preview_loading:"正在统计可复制内容…",copy_preview_diary:"日记",copy_preview_yearly:"年总结",copy_preview_quarterly:"季度总结",copy_preview_monthly:"月总结",copy_preview_weekly:"周总结",copy_preview_unit:"篇",copy_preview_total:"共 {{count}} 项",copy_preview_empty:"当前回溯范围内暂无可复制内容",algorithm_desc:"基于白守级联折叠算法，自动过滤冗余数据，构建我们共同的记忆脉络。",stats_yearly:"年度",stats_quarterly:"季度",stats_monthly:"月度",stats_weekly:"周度",stats_daily:"日记",tab_weekly:"周记",tab_monthly:"月报",tab_quarterly:"季报",tab_yearly:"年鉴",toast_copied:"共同回忆已复制",copy_prefix_label:"拷贝前缀",copy_prefix_hint:"会自动附加在拷贝内容的最前方（例如：Hi，这是我的回忆...）",cascade_folding_title:"记忆折叠规则",cascade_folding_content:`为了让 AI 能够最高效地理解记忆，我们采用了「级联折叠」算法：

1. 覆盖机制：如果某段时间已经生成了月报或季报，系统会认为 AI 已经掌握了这段时间的宏观记忆，因此会从共同回忆中折叠该时间内的原始条目。
2. 渐进式呈现：系统会优先保留最近几周的详细日记，而更早的记忆则主要通过周记、月报等更高维度的形式呈现。
3. 提炼 vs 冗余：这样做是为了在有限的 Token 长度内，让 AI 既能看到近期的细节，又能掌握全貌，避免让 AI 陷入海量原始日记的细节沼泽中。`,range_selector:"统计范围",load_data:"加载数据",loading:"数据加载中...",error_select_range:"请先选择日期范围",no_data_range:"该范围内没有日记数据",raw_data_desc:"无损导出指定日期范围内的所有日记数据，包含元数据和标签。",tap_to_select_range:"点击选择日期范围",raw_data_tab:"原始数据",history_tab:"历史归档",raw_data_title:"原始数据导出",lookback_folded:"共同的回忆 (过去 $months 个月 - 白守算法已折叠)",raw_data_range_label:"范围: ",raw_data_total_label:"总计: ",export_and_copy:"导出并复制",toast_raw_exported:"原始数据已复制到剪贴板",export_failed:"导出失败",confirm_delete_summary:"确认要删除这条总结吗？原始日记数据不会被删除。",delete_summary_title:"删除总结?",filter_month:"筛选月份",filter_year:"筛选年份",all_yearly:"全部年鉴",content_label:"总结内容",time_range_label:"时间范围",generate_all:"全部生成",stop_generating:"停止生成",stopping:"停止中...",concurrency_limit:"并发设限",concurrency_count:"并发: $count",add_summary_title:"添加$type",paste_hint:"在此粘贴 AI 生成的总结...",input_content:"请输入内容",added_success:"已添加",add_failed:"添加失败",no_summary_type:"暂无$type",delete_confirm:"确定要删除「$title」的总结吗？此操作不可撤销。",deleted_success:"已删除",click_to_generate:"点击右上角生成",title_weekly:"周记 ($range)",title_monthly:"$year年$month月 月报",title_quarterly:"$year年 Q$q 季度总结",title_yearly:"$year 年度总结",ai_suggestions:"AI 建议补全",detect_missing:"重新检测",detecting_missing:"检测中...",suggestion_generate:"建议生成",calendar_map:"查看日历地图",records_suffix:"条记录",diary_count:"日记条数",shared_memory:"共同回忆",shared_memory_copy_subtitle:"过去 $months 个月的共同回忆",shared_memory_desc:"已为您提取折叠后的高价值记忆片段，便于快速分享与回顾。",extraction_stats:"提取记忆",view_all:"查看全部",memory_gallery:"记忆画廊",panel_tab:"面板",rescan:"重新扫描",rescan_success:"扫描完成，统计数据已更新",rescan_failed:"扫描失败，请稍后重试",month_unit:"个月",stats_panel:"统计面板",generation_timeout:"AI 总结超时。这通常是由于网络连接慢或 AI 服务响应慢导致的，建议您在设置中切换为其它更稳定的 AI 模型后重试。",generation_failed:"生成失败",content_empty:"内容为空",model_not_configured:"模型未配置",model_not_configured_desc:`你还没有配置 AI 模型，无法生成总结。
