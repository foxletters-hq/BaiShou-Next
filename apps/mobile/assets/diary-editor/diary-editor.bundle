version when the app starts",view_github:"View GitHub repository"},developer:{title:"Developer Options",load_demo_data:"Load Demo Data",load_demo_desc:"Write demo diaries (won't clear existing data)",clear_all_data:"One-tap Clear Data (Dangerous)",clear_all_desc:"Clear all settings, diaries, summaries, images, and database.",load_demo_success:"✅ Demo data loaded",load_demo_failed:"❌ Load failed: $e",clear_warning_title:"Warning: Clear All Data",clear_warning_content:`This will IRREVERSIBLY clear all your data and restore the app to factory state.

Are you absolutely sure you want to continue?`,confirm_clear:"Confirm Clear",clear_success_title:"Clear Successful",clear_success_content:"All data cleared. Please restart the app manually.",clear_failed:"Failed to clear data: $e",debug_title:"🛠 Developer Debug",data_management:"Data Management",load_demo_full_desc:"Load sample diaries for testing. Will not delete existing data.",loading_status:"Loading...",clear_all_success:"所有核心数据与环境已抹除，点击确认重启容器以进入安全着陆模式。",clear_success:"清理完成",clear_agent_db_desc:"Nukes contexts, forces resync upon next engine cold boot.",clear_agent_db:"Flush Agent Overrides",clear_agent_success:"Agent database cleared. Restart the app to rebuild it.",insert_compression_test:"Insert compression test chat",insert_compression_test_desc:"Create a 15-round simulated AI dialogue with tool calls; data size is derived from the bound companion's compression threshold.",insert_compression_test_success:"Compression test chat created ({{rounds}} rounds, ~{{tokens}} tokens)",insert_compression_test_failed:"Insert failed: ",open_onboarding:"Preview onboarding",open_onboarding_desc:"Open the first-launch welcome flow to review copy and layout (does not change your data)."},privacy:{title:"Privacy & Philosophy",data_ownership:"1. Data Sovereignty",data_ownership_desc:"BaiShou believes memory is a soul extension. Your data is stored locally. Unauthorized uploads never occur beyond your chosen AI/Sync providers.",local_first:"2. Local First",local_first_desc:"Write diaries offline seamlessly. AI summaries are generated on-demand; we don't store your generated texts.",transparency:"3. Transparency & Security",transparency_desc:"Supports end-to-end data export. Take your memories with you anytime via ZIP or sync to your own S3/WebDAV space."},agent:JSON.parse(`{"partner_label":"Partner","no_model_selected":"No Model Selected","start_new_conversation":"Start a new conversation","start_conversation_hint":"Type something below, or click on the left to start a new chat~","load_more_conversations":"Load more conversations","tools":{"built_in":"Built-in Tools","community":"Community Tools","community_coming_soon":"You will be able to install and share tools from the community","tool_call":"Tool Call","tool_call_results":"Tool Calls · {{count}} results","community_market_coming":"Community tool market coming soon","diary_read":"Read Diary","diary_edit":"Edit Diary","diary_delete":"Delete Diary","diary_list":"List Diaries","diary_search":"Search Diary","summary_read":"Read Summary","message_search":"Search Messages","vector_search":"Semantic Search","memory_store":"Store Memory","memory_delete":"Delete Memory","current_time":"Current Time","web_search":"Web Search","web_search_not_enabled":"Web search not enabled. Please enable it in the toolbar.","param_max_results":"Max Results","param_max_results_desc":"Maximum number of results returned per AI search","param_max_results_tooltip":"Limits how many diary search hits are returned in one query.","diary_read_tooltip":"Lets the partner read full diary entries by date. Up to 20 entries per call; pass exact dates (use List or Search Diaries first if unknown).","diary_edit_tooltip":"Edit an existing diary—append with a timestamp or overwrite the full entry.","diary_delete_tooltip":"Permanently delete a diary entry. This cannot be undone.","diary_list_tooltip":"List diary dates in a range with short previews.","diary_search_tooltip":"Keyword search across your personal diaries (not the public internet).","summary_read_tooltip":"Read AI-generated weekly, monthly, quarterly, or yearly summaries.","message_search_tooltip":"Search past chat messages across sessions by keyword.","memory_store_tooltip":"Save important facts to long-term memory for later semantic recall.","memory_delete_tooltip":"Remove stored memories. Confirm with the user before deleting.","auto_inject_time":"auto inject time","auto_inject_time_desc":"Automatically inject time on each turn","auto_inject_time_tooltip":"When enabled, the current date and time are injected into the system context on every turn. When disabled, the partner will not know the current time by default; use the current_time tool when needed.","param_search_engine":"Search Engine","param_search_engine_desc":"Select the engine used for web search","url_read":"Read Webpage","param_max_length":"Content Length Limit","param_max_length_desc":"Maximum characters returned when reading a web page","param_rag_enabled":"RAG Vector Compression","param_rag_enabled_desc":"When enabled, search results are filtered by relevance via vector retrieval (requires an embedding model)","param_rag_max_chunks":"Total Max Chunks","param_rag_max_chunks_desc":"Maximum number of extracted chunks to provide to the AI as reference, determining the upper limit of token consumption","param_rag_chunks_per_source":"Max Chunks per Source","param_rag_chunks_per_source_desc":"Maximum number of chunks extracted from a single website, preventing a long article from dominating the results","param_plain_snippet_length":"Plain Text Snippet Length Limit","param_plain_snippet_length_desc":"When an Embedding model is not configured, the system falls back to concatenating the raw text. To avoid consuming too many Tokens, text will be truncated per site after this length","param_tavily_api_key":"Tavily API Key","param_tavily_api_key_desc":"Tavily search API key (get free at https://app.tavily.com)","param_exa_api_key":"Exa API Key","param_exa_api_key_desc":"Exa search API key (get at https://dashboard.exa.ai/api-keys)","param_anysearch_api_key":"AnySearch API Key","param_anysearch_api_key_desc":"AnySearch API key (free at https://www.anysearch.com/console/api-keys)","shortcuts":{"translate_name":"Translate","translate_content":"Please translate the following text into English faithfully and elegantly (including explanations of professional terms):\\n\\n","summarize_name":"Summarize","summarize_content":"Please summarize the core meaning behind the following content:\\n\\n"},"web_search_desc":"Search the internet for current information, news, and real-time data. You may use this when the user asks about recent events, current facts, or anything that requires up-to-date information beyond your training data.\\n\\nIMPORTANT: This tool searches the PUBLIC INTERNET only. Do NOT use this to search the user's personal diary entries — use diary_search for that.\\n\\nYou may provide 2-3 search queries with different angles/keywords to get comprehensive results. For example, if the user asks about \\"iPhone 16 vs Samsung S25\\", you could search [\\"iPhone 16 specs review\\", \\"Samsung S25 specs review\\", \\"iPhone 16 vs Samsung S25 comparison\\"].\\n\\nResults include clickable [title](url) citations — use the url_read tool to read specific pages in detail.","vector_search_desc":"Semantic search over conversation history and stored memories. You may use this when recalling past content not already covered in the current context (including any rolling compression summary). Optionally narrow results with start_date / end_date (YYYY-MM-DD). Returns semantically relevant snippets with scores.","url_read_desc":"Read the text content of a specific webpage URL directly. Use this when you have a specific link you want to analyze or summarize, instead of searching the whole web.","summary_read_desc":"Read AI-generated summaries (weekly, monthly, quarterly, or yearly). Returns the summary content for a specific time period. Use diary_list or diary_search for raw diary entries instead.","message_search_desc":"Search past conversation messages across all sessions by keyword. Returns matching message snippets with session title and date. Useful when the user references something discussed before, or when you need to recall previous conversations.","memory_store_desc":"Store important information as long-term memory for later semantic search retrieval. Use this tool when the user expresses preferences, makes decisions, or when you encounter information worth remembering. Stored memories are vectorized and can be retrieved via the vector_search tool.","memory_delete_desc":"Delete stored memories by semantic search. First searches for memories matching the query, then deletes the matching entries. Use this when the user wants to forget something or remove outdated information. IMPORTANT: Always confirm with the user before deleting memories.","diary_write":"Write Diary","diary_write_desc":"Create a new diary entry for a given date. If a diary entry already exists for that date, use diary_edit instead.","diary_search_desc":"Search the user's PERSONAL DIARY/JOURNAL entries by keyword. Returns matching diary dates and content snippets. Use this when the user asks about their own past experiences, memories, or personal records.\\n\\nIMPORTANT: This tool ONLY searches the user's personal diary entries stored locally, NOT the internet. To search the internet, use the web_search tool instead.","diary_read_desc":"Read the full content of one or more diary entries by their exact dates. Supports reading up to 20 entries at once. Use diary_list or diary_search first if you do not know the exact date.","diary_list_desc":"List all diary entries within a date range (inclusive). Returns a list of dates that have diary entries, along with a brief preview of each entry. Use this to discover which days the user has written diaries.","diary_edit_desc":"Modify an existing diary entry. Default mode is \\"append\\", which adds new content with an automatically inserted timestamp header (##### HH:mm). Use \\"overwrite\\" mode to replace the entire content. Tags are automatically merged with existing ones.","diary_delete_desc":"Delete a specific diary entry. This is a destructive action and cannot be undone. Always double check before using.","current_time_desc":"Get the current real-world time, date, and day of the week. Very useful for answering questions related to time calculations, age, absolute dates, etc.","compress_context_upstream":"Upstream context compression","compress_context_upstream_desc":"Merge earlier dialogue into a rolling summary before the next model request (upstream).","compress_context_downstream":"Downstream context compression","compress_context_downstream_desc":"Refresh the summary and prune long tool outputs after the assistant reply is saved (downstream)."},"chat":{"companion_mode":"Deep Companion","empty_hint":"Try asking: 'What diaries did I write this week?'","input_system_prompt_hint":"Enter custom Partner behavior rules...","retry":"Retry","resend":"Resend","thinking_time":"Thinking... {{time}}","thought_time":"Thought process: {{time}}","compression_thought_time":"Thinking time {{time}}","compression_summary_time":"Summary generation time {{time}}","thought_process":"Thought Process","thinking":"Thinking...","thought_process_prefix":"Thought Process","branch":"Create branch from here","branch_success":"Branch created successfully","branch_failed":"Failed to create branch","err_format":"Invalid request format, please check message content and retry","err_unauthorized":"Invalid API Key or no access to this model","err_too_many_requests":"Too many requests, please try again later","err_server":"Server temporarily unavailable, please try again later","err_timeout":"Request timeout, please check network and retry","err_network":"Could not connect to server, please check network settings","start_chat":"Start chatting with Partner","session_settings":"Session Settings","session_name":"Session Name","system_prompt_label":"Behavior Rules (System Prompt)","you_label":"You","ai_label":"AI Companion","regenerate":"Regenerate","copy":"Copy","input_hint":"Type a message...","err_no_model":"Please configure an AI model in Settings first","cost_detail_title":"Cost Estimation Details","cost_total":"Total Cost","cost_disclaimer":"Costs are for reference only, subject to official rates.","context_chain":"Context Messages","tab_context":"Context","tab_compressed":"Compressed","tab_original":"Original","tab_prompt":"Prompt","cost_cumulative_title":"Cumulative API Usage","cost_cumulative_total":"Total Cost","cost_cumulative_input":"Total Input","cost_cumulative_output":"Total Output","cost_cumulative_cache_read":"Cache read","cost_cumulative_cache_write":"Cache write","cost_context_title":"📐 Current Context","cost_context_size":"Context Size","cost_no_data":"No data yet","tokens_unit":"tokens","round_input":"Input","round_output":"Output","round_cache_read":"Cache read","round_cache_write":"Cache write","cache_read":"Cache read","cache_write":"Cache write","cache_label":"Cache: ","cache_read_short":"Cache","cache_write_short":"Cache write","round_cost":"Cost","full_call_chain":"Full call chain","tab_call_chain":"Call chain","next_request_estimate":"Next request estimate","compression_help_aria":"View conversation compression rules","compression_help_modal_title":"Conversation compression","compression_help_intro":"When context tokens exceed your companion's threshold, earlier turns are merged into a \\"conversation compression\\" summary, then sent to the model together with recent full turns.","compression_help_trigger_title":"When it runs","compression_help_trigger_body":"Enable Auto Compress on the companion and set a token threshold (0 disables). Checked before each send and after each reply; above threshold the model updates the summary and long tool outputs may be pruned.","compression_help_chain_title":"Call chain layout","compression_help_chain_1":"System prompt (standalone block)","compression_help_chain_2":"Conversation compression (standalone block between rounds)","compression_help_chain_3":"Round 1, 2…: only post-compression turns, renumbered from 1","compression_help_footer_title":"Footer metrics","compression_help_footer_tokens":"Context tokens: rough estimate of system prompt + compression summary + messages in the current window","compression_help_footer_rounds":"Context rounds: user turns after compression / companion round limit (unlimited = no round cap)","compression_help_keep_title":"Keep recent turns","compression_help_keep_body":"The last N user turns stay verbatim (assistant replies and tool calls in each turn). Older content goes into the summary. Configure N on the companion.","compression_help_branch_title":"Branch & rewind","compression_help_branch_body":"Branching copies messages and a valid compression snapshot. Resend/edit on an earlier message drops the snapshot anchor if that message was removed, restoring full text instead of the summary.","compaction_summary":"Conversation compression","compaction_between_rounds":"Earlier turns are compressed; numbering below restarts at round 1","compressing_context":"Compressing conversation…","compressing_context_hint":"Earlier messages are being merged into a summary. You can continue once it finishes.","compression_divider":"Conversation compressed","compression_divider_aria":"Conversation compression boundary","compression_stream_waiting":"Waiting for model output…","recompress_btn":"Re-compress","recompress_running":"Compressing…","recompress_completed":"Recompression complete","compression_completed":"Conversation compressed","compression_thinking":"Compression thinking…","compression_thought":"Compression reasoning","compression_thinking_waiting":"Waiting for compression model to think…","recompress_hint":"Regenerate the summary using the same message span as the last compression","recompress_banner_hint":"Regenerating summary — you can switch items or pages; it will update when done","recompress_range_hint":"Choose which conversation rounds (full turns before the compression cutoff) to send to the model for a new summary.","recompress_from":"From round","recompress_to":" to round ","recompress_round_suffix":"","recompress_merge_prior":"Merge current summary before summarizing","recompress_submit":"Start compression","recompress_failed":"Re-compression failed","est_context_tokens":"Context","context_rounds":"Context rounds","context_rounds_unlimited":"No limit","round_label":"Round {{n}}","current_round":"Current","round_items":" items","this_round_usage":"This round","resize_panel":"Drag to resize","no_context_messages":"No context sent to the model yet","select_chain_item":"Select an item on the left to view full content","pricing_table_title":"Pricing Table Info","pricing_last_updated":"Last Updated","pricing_source":"Pricing Data Source","pricing_source_tooltip":"Click to view raw API pricing data in external browser","pricing_refresh":"Refresh","pricing_refreshing":"Refreshing...","pricing_refresh_failed":"Failed to refresh pricing","pricing_refresh_network_error":"Network error, please check your connection","pricing_unknown":"Unknown","pricing_boot_load_failed":"Could not fetch the models.dev pricing table. Cost estimates may be inaccurate — check your network and refresh in the billing panel.","pricing_just_now":"Just now","pricing_minutes_ago":"$count minutes ago","pricing_hours_ago":"$count hours ago","role_system":"📋 System","role_user":"User","role_assistant":"✨ Assistant","role_tool":"🔧 Tool","empty_content":"(empty)","no_content":"(no content)","search_emoji":"Search Emoji...","select_partner":"Select Companion","manage":"Manage","recent_chats":"Recent Chats","select_all":"Select All","deselect_all":"Deselect All","delete_confirm_multi":"Delete $count conversations? This cannot be undone.","delete_count":"Delete ($count)","chat_count":"$count conversations","new_chat_label":"New Chat","collapse_sidebar":"Collapse Sidebar","expand_sidebar":"Expand Sidebar","assistant_init_failed":"Assistant initialization failed: $e","search_recent":"Search recent chats...","no_search_results":"No matching results","load_more":"Load more","manage_pinned":"Manage pinned companions","delete_msg_confirm":"Are you sure you want to delete this message history? This action is irreversible.","scroll_to_bottom":"Back to bottom","cancel_select_all":"Deselect All","memory":"AI Memory","reasoning":"Thinking...","using_tool":"Running tool...","readAloud":"Read Aloud","tts_off":"Voice Off","tts_always":"Always Read","tts_manual":"Manual Read","tts_no_api":"TTS feature is not available","tts_not_configured":"TTS model not configured, please configure a TTS model in settings","tts_provider_not_found":"TTS provider not found","tts_api_error":"TTS API request failed","tts_failed":"Speech synthesis failed"},"sessions":{"history":"Chat History","settings":"Partner Settings","new_chat":"New Chat","companion_tab":"Companion","session_tab":"Session","companion_title":"Deep Companion Mode","companion_desc":"Start chatting directly without managing sessions","continue_chat":"Continue Chat","no_history":"No conversation history yet","start_new":"Start New Chat","delete_title":"Delete Chat","delete_confirm":"Delete \\"{title}\\"?","delete_btn":"Delete","companion_switch":"Companion Mode","companion_on":"Enabled — Single continuous chat, no session concept","companion_off":"Disabled — Multi-session mode","memory_window":"Context Window","memory_window_desc":"Send recent {count} messages to the model","persona":"Persona","persona_hint":"Describe the Partner's identity and style","behavior":"Behavior Rules","behavior_hint":"Describe rules the Partner must follow","rename":"Rename","rename_hint":"Enter new session name","actions":"Actions","pin":"Pin Chat","unpin":"Unpin","delete_session":"Delete Chat","default_title":"New Chat","unnamed_session":"Unnamed Session","companion_session_title":"Companion Mode","groupPinned":"Pinned","groupToday":"Today","groupYesterday":"Yesterday","groupWeek":"Past 7 Days","groupOlder":"Older","newChat":"New Chat","noResults":"No results...","total_count":"Total Sessions","total_messages":"Total Messages","active_agents":"Active Partners","management_title":"Session Management","batch_manage":"Batch Manage","pinned_only":"Pinned 📌","empty":"No sessions yet..."},"rag":{"title":"RAG Memory Manager","search_hint":"Search memories...","clear_all":"Clear","clear_all_title":"Clear All Memories","clear_all_content":"Are you sure you want to delete all embedded vector data? This action cannot be undone.","clear_confirm":"Confirm Clear","delete_tooltip":"Delete","stat_total":"Total","stat_model":"Model","stat_dimension":"Dimension","rag_disabled_hint":"Global memory is disabled, Partner will not use RAG retrieval","dimension_detected":"Auto-detected: \${dimension}D","dimension_detecting":"Detecting...","dimension_click_detect":"Click to detect","dimension_not_configured":"Embedding model not configured","detect_success":"Detected: \${dimension} dimensions","detect_failed":"Detection failed, please check model config","detect_error":"Detection failed: $error","clear_dim_title":"Clear Current Dimension","clear_dim_content":"Delete all \${dimension}-D vector data?\\nOther dimensions will not be affected.","clear_dim_confirm":"Confirm Delete","clear_dim_no_config":"No dimension configured, cannot clear","clear_dim_success":"Deleted $deleted entries of \${dimension}-D vectors","batch_embed_title":"Batch Embed All Diaries","batch_embed_content":"This will read all diary entries and generate vector embeddings.\\nExisting entries will not be re-embedded.\\nThis may take some time.","batch_embed_start":"Start Embedding","batch_embed_progress":"Embedding $progress/$total","batch_embed_success":"Done! Embedded $count diaries","batch_embed_error":"Batch embed error: $error","embedding_not_configured":"Please configure Embedding model first","no_memories_yet":"No memories yet","no_memories_match":"No matching memories found","memories_auto_hint":"Memories will be stored here automatically after chatting with Agent","action_clear_dimension":"Clear Dimension","action_batch_embed":"Embed All Diaries","action_add_memory":"Add Memory","add_memory_title":"Add Memory","add_memory_hint":"Enter content to remember...","add_memory_save":"Save","add_memory_success":"Memory saved and embedded","edit_memory_title":"Edit Memory","edit_memory_success":"Memory updated and re-embedded","retrieval_params":"Retrieval Parameters","similarity_threshold":"Similarity Threshold","migration_pending_title":"Incomplete Migration Detected","migration_pending_content":"The previous embedding migration was not completed (possibly due to app crash).\\n\\nContinue migration? Backup data is still safe.","migration_mismatch_title":"Heterogeneous Model Detected","migration_mismatch_content":"The memory in the current workspace uses a different embedding model.\\nThis will cause old memories to be completely hidden from AI searches due to vector dimension mismatch.\\n\\nDo you want to migrate and unify them to the latest global model? (If you click [Later], you can still do this manually in the RAG page anytime.)","migration_later":"Later","migration_continue":"Continue Migration","migration_error":"Migration error: $error","migration_model_changed_title":"Embedding Model Changed","migration_model_changed_content":"Embedding model change detected.\\n\\nOld vector data is incompatible with the new model dimensions, all data needs to be re-embedded.\\n\\nThis will:\\n• Backup existing text metadata\\n• Clear old vectors and re-embed with new model\\n• Auto-verify data integrity after completion\\n\\nProcess runs asynchronously in the background.","migration_start_now":"Re-embed Now","migration_preparing":"Preparing to re-embed...","migration_switch_warning_title":"Change embedding model?","migration_switch_warning_content":"The new model may be incompatible with existing vectors. Diary embeddings will be rebuilt in the background. Continue?"},"assistant":{"management_title":"Companion Management","create_title":"Create Companion","edit_title":"Edit Companion","name_label":"Companion Name","name_hint":"Enter name","search_hint":"Search companions...","name_required":"Please enter companion name","partner_info_label":"Companion Info","prompt_label":"System Prompt","prompt_hint":"Define the companion's role, behavior and response style...","context_window_label":"Context Turns","context_window_desc":"How many recent conversation turns are sent to the model. One turn starts with your message and includes the assistant reply and any tool calls in that turn. More turns mean longer memory but higher token usage.","set_default":"Set as Default","set_default_desc":"Automatically use this companion for new conversations","default_label":"Default","no_prompt":"⚠️ Empty system protocol stream...","empty_hint":"Your matrix is empty. No mind cores deployed yet.","create_first":"Initialize First Protocol","remove_avatar":"Remove Avatar","delete_confirm_title":"Warning: Erase Mind Pattern?","delete_confirm_content":"Are you sure you want to permanently obliterate this agent's data? It cannot be undone.","settings_entry":"Partner Management","select_title":"Select Companion","clear_selection":"Clear","default_tag":"Default","no_assistant":"No Companion","pin_to_sidebar":"Pin to Sidebar","unpin_from_sidebar":"Unpin from Sidebar","select_builtin_avatar":"Built-in","avatar_choice_title":"Choose avatar","builtin_avatars":"Built-in avatars","upload_avatar":"Upload","reset_builtin_avatar":"Reset default","description_label":"Description","description_hint":"Briefly describe the companion's purpose...","context_unlimited":"∞ Unlimited","context_limited":"Limited","context_unlimited_desc":"No turn limit—all conversation history (each turn includes your message, the reply, and tool calls) is sent to the model.","bind_model_label":"Bind Model","use_global_model":"Use Global Model","select_model_label":"Select Model (Use Global Default)","bind_model_desc":"Once bound, new conversations with this partner will prioritize the selected model","select_model_title":"Select Model","compress_label":"Auto Compress","compress_disabled_desc":"Conversations will not be auto-compressed, all messages are retained","compress_enabled_desc":"Old messages are compressed to summaries when threshold is exceeded","compress_tooltip":"When conversation context exceeds the set Token threshold, the system will automatically compress early conversation content, keeping recent conversation rounds.","compress_token_threshold_label":"Token threshold","compress_keep_turns_label":"Keep Recent Turns","compress_keep_turns_unit":"$count turns","compress_keep_turns_desc":"When compression triggers, the most recent turns are kept in full. One turn starts with your message and includes the assistant reply and any tool calls in that turn; older turns are summarized.","compress_keep_turns_tooltip":"When compression triggers, the specified number of recent turns are kept as full text (your message, the reply, and tool calls in each turn) so context stays coherent.","compress_system_prompt_label":"Compression prompt","compress_system_prompt_desc":"System instruction sent to the model when generating the conversation compression summary. Use Reset to load the built-in default for your UI language.","compress_system_prompt_reset":"Reset to default","default_assistant_name":"Latte","default_assistant_desc":"An ancient vampire noble and BaiShou's eternal memory guardian.","keep_one_error":"Must keep at least one companion","new_name_prompt":"Enter new assistant name:","edit_name_title":"Edit Assistant Name","unpin":"Unpin from Sidebar","window_size":"Window Size","delete_confirm_desc":"This will permanently delete all configurations for this assistant. This action cannot be reversed.","title":"Partner Management","create_new":"Add Partner","create":"Create Companion","current":"Current","memory_label":"Memory","current_partner":"Current Companion","delete_confirm":"Delete this companion?","picker_no_selection":"Select a companion to view details","click_to_rename":"Click to rename","not_found":"Companion not found","created":"Companion created","updated":"Companion updated","deleted":"Companion deleted","kind_companion":"Companion","kind_work":"Work","kind_companion_description":"Can edit diaries and search RAG memories—ideal for daily companionship and life journaling.","kind_work_description":"For knowledge lookup and work tasks only—no diary or memory access."},"provider":{"add_title":"Add AI Provider","add_type_label":"Provider Type (Client)","add_name_label":"Provider Name","add_name_hint":"e.g.: My OpenAI Proxy","add_button":"Add","delete_title":"Delete Provider","delete_confirm":"Delete \\"$name\\"?","delete_button":"Delete","delete_tooltip":"Delete Provider","custom_tag":"Custom"},"profile":{"default_nickname":"BaiShou User","no_nickname":"Unset nickname","edit_nickname":"Edit Nickname","edit_nickname_prompt":"Please enter a new nickname:"},"recall":{"title":"Context Recovery","tab_diary":"Diaries","tab_memory":"Vector Knowledge","search_hint":"Search keywords","no_results":"No history match found in the vault.","search_timeout":"Semantic search timed out. Please try again later.","selected":"Selected","inject":"Extract to Dialogue Context"},"error":{"api_key":"API Key expired or invalid. Please update your key in model settings.","rate_limit":"Too many requests or rate limit exceeded. Please try again later.","network":"Network connection failed. Please check your connection or proxy settings.","timeout":"Request timed out. Please try again.","quota":"Insufficient account quota or balance reported by the provider.","unknown":"An error occurred: {{msg}}","create_session":"Failed to create session due to system error: {{msg}}","vision_not_supported":"This model doesn't support image recognition — try switching to a vision model~"},"generation_failed":"Reply generation failed","stream_cancelled":"Generation cancelled","trace_title":"Trace [{{modelId}}]","default_assistant_name":"Latte","default_assistant_prompt":"You are Latte, BaiShou's dedicated AI companion.","default_assistant_desc":"An ancient vampire noble and BaiShou's eternal memory guardian.","delete_session_confirm":"Are you sure you want to permanently delete this session? This cannot be undone.","batch_delete_confirm":"Are you sure you want to delete the selected {{count}} sessions? This cannot be undone.","renamed_toast":"Renamed to \\"{{title}}\\"","rename_session":"Rename Session","sidebar":{"expand":"Expand Sidebar","collapse":"Collapse Sidebar","pin_hint":"You can pin partners here","recent_chats":"Recent Chats","search_hint":"Search recent chats...","no_recent_chats":"No recent chats. Start one now!"},"switchModel":"Switch Model","noMatchModel":"未发现可搭载的模型","manageProviders":"管理模型与供应商"}`),input:{upload_attachment:"Upload Attachment",attachment_source_title:"Choose attachment source",attachment_camera:"Camera",attachment_photo_library:"Photo Library",attachment_file_manager:"Files",attachment_permission_denied:"Camera or photo library permission is required",shortcut_command:"Shortcut Command",vision_not_supported_warn:"The current model does not support image recognition. We recommend switching to a multimodal model (e.g. gpt-4o, gemini-1.5) for the best results.",model_no_vision_hint:"Current model does not support images. Please switch to a multimodal model",file_too_large:"File size exceeds limit (max 512KB)"},shortcut:{label_name:"Shortcut Name",label_hint:"e.g. Translate",command_label:"Command (for triggering)",command_hint:"e.g.: review, translate",content_prompt:"Content",content_hint:"Please translate the following text for me.",default_tag:"Cmd",title:"Shortcuts",no_match:"No matching shortcuts found",search_placeholder:"Search shortcuts...",drag_sort_hint:"Use the arrows on the left to reorder",move_up:"Move up",move_down:"Move down",drag_handle:"Reorder",add_short:"Add",no_shortcuts_hint:"No shortcuts yet. Create one to get started.",delete_confirm:"Delete this shortcut?",duplicate_command:"A shortcut with this command already exists. Please choose another phrase.",input_slash_hint:"Type / in an empty input to match shortcuts. Keep typing to filter, then press Enter or tap an item to insert its text.",manager_title:"Shortcut Manager",add_custom_command:"Add Shortcut",back:"Back",edit:"Edit"},models:{tts:{advanced_title:"Text-to-Speech (TTS) Advanced Settings",voice_label:"Voice ID",voice_placeholder:"e.g. alloy, echo, Mia, 冰糖",voice_hint:"Enter the specific voice / speaker ID supported by your current TTS model. E.g. alloy for OpenAI, 冰糖 or Mia for Xiaomi MiMo TTS.",speed_label:"Speed",format_label:"Response Format"},click_to_assign:"Click to assign default model",routing_desc:"Assign specialized models for different daily tasks.",switch_model:"Switch Model",vision_supported:"Supports vision / multimodal"},dashboard:{greeting:"又见面了，今天过得怎样？",shared_memory_desc:"Adjust the lookback months to export recent summary context for RAG or LLMs.",lookback_months:"Past {{count}} months",copy_to_ai:"Copy 给 AI"},chat:{send_to:"发给 {{name}}...",new_session:"新对话",pinned:"已固定",respond_to_message:"Respond to this message",copy_code:"Copy",view_context_tree:"View conversation context tree",click_to_rename:"Click to rename",partner_avatar:"Partner",times_count:"times",items_count:"items"},"**":"**","*":"*","[":"](url)","![":"](image_url)",activity:{yearly_records:"Yearly Diary Records",monthly_records:"Monthly Diary Records",interactions:"diaries",select_year:"Select Year",select_month:"Select Month",all_months:"All Months"},assistant:{matrix_title:"AI 助手控制台 (Assistant Matrix)",matrix_desc:"用来精细化管理和创造专属助理对象，包含预设提示词配置与单独工作空间关联。",enter_matrix:"进入控制管理",prompt:"提示词",memory:"记忆",threshold_val:"阈值 {{val}}",select_title:"Select Companion",no_assistant:"No Companion",create_title:"Create Companion",picker_no_selection:"Select a companion to view details",clickToRename:"Click to rename"},gallery:{summary:"Summary",weekly_report:"Weekly Report",yearly_summary:"Yearly Summary",empty_desc:"No records yet. Add more photos in chats or diary entries!",record_unit:"records",filter_all_years:"All Years",select_year:"Select Year"},hotkey:{enable_global:"Enable Global Hotkey",enable_global_desc:"Toggle the console overlay from anywhere",enable_global_desc