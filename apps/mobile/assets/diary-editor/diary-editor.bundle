ns.","agent_behavior":"Agent behavior","agent_behavior_desc":"Global context window, compression thresholds, and persona","agent_behavior_saved":"Agent behavior settings saved","context_window_size":"Agent context window size","context_window_size_hint":"Number of history messages per conversation (default 20)","compress_token_threshold":"Companion compress token threshold","compress_token_threshold_hint":"Token count that triggers compression in deep companion mode (default 8000)","truncate_token_threshold":"Companion truncate token threshold","truncate_token_threshold_hint":"Truncate conversation before this many tokens when compressing (default 4000)","agent_persona":"Agent persona","agent_persona_hint":"Role and personality of the agent","agent_persona_placeholder":"e.g. You are an AI companion helping the user review diaries.","agent_guidelines":"Agent guidelines","agent_guidelines_hint":"Behavior rules the agent should follow","agent_guidelines_placeholder":"e.g. Use tools to read diaries; do not fabricate facts.","pinned_assistant_ids":"Pinned assistant IDs","pinned_assistant_ids_hint":"Comma-separated IDs (max 3)","pinned_assistant_ids_placeholder":"e.g. assistant-1, assistant-2","reset_defaults_title":"Reset to defaults","reset_defaults_confirm":"Reset all agent behavior settings to defaults?","reset_defaults":"Reset defaults","global_models_saved":"Global model settings saved","configure_providers":"Configure providers","manage_providers":"Manage providers","not_set":"Not set","no_models_available":"No models available. Configure providers first.","disabled_tools":"Disabled","web_search_saved":"Web search settings saved","summary_saved":"Summary settings saved","tool_saved":"Tool settings saved","mcp_saved":"MCP settings saved","rag_saved":"RAG settings saved","system_prompt":"Base System Prompt","advanced":"高级","system_prompt_hint":"例如: 你是一个无所不知但只说重点的AI助手...","temperature":"Temperature / Creativity","temp_low":"0.0 (Strict)","temp_mid":"1.0 (Balanced)","t