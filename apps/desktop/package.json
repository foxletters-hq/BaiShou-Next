{
  "name": "@baishou/desktop",
  "version": "1.0.4",
  "description": "白守 (BaiShou) — 记录你珍贵的回忆",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "node ../../node_modules/vitest/vitest.mjs run --config vitest.config.mts",
    "test:watch": "vitest",
    "start": "electron-vite preview",
    "predev": "node ../../scripts/sync-app-icon.mjs && node ../../scripts/sync-app-version.mjs",
    "dev": "electron-vite dev",
    "prebuild": "node ../../scripts/sync-app-icon.mjs && node ../../scripts/sync-app-version.mjs",
    "build": "npm run typecheck && electron-vite build",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3,sqlite-vec",
    "electron-builder": "npm run rebuild:native && node scripts/electron-builder.mjs",
    "build:unpack": "node scripts/ensure-not-running.mjs && npm run build && npm run electron-builder -- --dir && node scripts/verify-desktop-pack.mjs",
    "build:inno": "node scripts/build-inno.mjs",
    "build:win": "npm run build:unpack && npm run build:inno",
    "build:mac": "electron-vite build && npm run electron-builder -- --mac",
    "build:linux": "electron-vite build && npm run electron-builder -- --linux"
  },
  "dependencies": {
    "@baishou/ai": "workspace:*",
    "@baishou/core-desktop": "workspace:*",
    "@baishou/database-desktop": "workspace:*",
    "@baishou/shared": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "sqlite-vec": "^0.1.9",
    "@baishou/store": "workspace:*",
    "@baishou/ui": "workspace:*",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^3.0.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "archiver": "^7.0.1",
    "bonjour-service": "^1.3.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "electron-context-menu": "^4.1.2",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "extract-zip": "^2.0.1",
    "lucide-react": "^1.7.0",
    "minio": "^8.0.7",
    "mime-types": "^2.1.35",
    "multer": "^2.1.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.0",
    "webdav": "^5.9.0",
    "zod-to-json-schema": "^3.25.2",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.6",
    "@types/extract-zip": "^2.0.3",
    "@types/node": "^25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "^6.0.2",
    "vite": "^7.1.10",
    "vitest": "^4.1.2"
  }
}
